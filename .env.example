# ── Local development ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# API listen address (default: :8080)
# Not needed on Heroku — Heroku injects PORT automatically.
ADDR=:8080

DB_ADDR=postgres://blog:blog@localhost:5432/blog?sslmode=disable

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Heroku: not used — images go to Cloudinary instead
UPLOADS_DIR=./uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
