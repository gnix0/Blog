# ── Local development ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# API listen address (default: :8080)
# Not needed on Heroku — Heroku injects PORT automatically.
ADDR=:8080

# PostgreSQL connection string
# Local dev:  postgres://blog:blog@localhost:5432/blog?sslmode=disable
# Docker:     postgres://blog:blog@postgres:5432/blog?sslmode=disable
# Heroku:     set automatically as DATABASE_URL by the Postgres add-on
DB_ADDR=postgres://blog:blog@localhost:5432/blog?sslmode=disable

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Directory for locally-uploaded images (dev only)
# Docker: /uploads (mounted volume)
# Heroku: not used — images go to Cloudinary instead
UPLOADS_DIR=./uploads

# ── Cloudinary (production image uploads) ────────────────────────────────────
# Leave blank in local dev to store uploads on disk instead.
# Sign up at https://cloudinary.com (free plan is sufficient).
# Credentials: cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
